---
const testCards = [
  {
    title: 'Inversión Segura',
    description: 'Tu dinero trabaja para ti y para tu tierra.',
    extraInfo: 'Cartera diversificada con retornos anuales del 8-12%. Sin mínimo de entrada. Gestión profesional.',
  },
  {
    title: 'Comunidad Activa',
    description: 'Conectá con otros inversores del Caribe.',
    extraInfo: '+1,000 miembros en 15 países. Eventos mensuales, networking y oportunidades.',
  },
  {
    title: 'Asesoría Personal',
    description: 'Te acompañamos en cada paso del camino.',
    extraInfo: 'Equipo de expertos disponible 24/7. Reports mensuales personalizados.',
  },
];
---

<section class="py-32 bg-[#0A1628] relative overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 30px 30px;"></div>
  </div>
  
  <div class="max-w-6xl mx-auto px-8 lg:px-12 relative z-10">
    <div class="text-center mb-16">
      <span class="inline-block bg-[#F59E0B]/20 text-[#F59E0B] px-5 py-2 rounded-full text-sm font-semibold mb-4">Test Zone</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Extra Hover Animation</h2>
      <p class="text-white/60 max-w-xl mx-auto">
        Hover normal = escala suave. Hover sostenido 0.4s = popup flotante en capa independiente.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testCards.map((card, index) => (
        <div 
          class="hover-layer-card group relative min-h-[12rem]"
          data-index={index}
        >
          <!-- Card base (visible siempre) -->
          <div class="base-card w-full bg-white/5 backdrop-blur-sm border-2 border-white/10 rounded-2xl p-6 cursor-pointer transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-[#F59E0B]/20 flex items-center justify-center flex-shrink-0">
                <div class="w-5 h-5 rounded-full bg-[#F59E0B]"></div>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white">{card.title}</h3>
                <p class="text-white/60 text-sm mt-1">{card.description}</p>
              </div>
            </div>
          </div>
          
          <!-- Popup (aparece en hover prolongado) -->
          <div class="expanded-card absolute left-0 right-0 top-0 bg-gradient-to-br from-[#1a2744] to-[#0A1628] border-2 border-[#F59E0B]/50 rounded-2xl p-6 cursor-pointer z-10 overflow-hidden">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-[#F59E0B] flex items-center justify-center flex-shrink-0">
                <div class="w-5 h-5 rounded-full bg-white"></div>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white">{card.title}</h3>
                <p class="text-white/80 text-sm mt-1">{card.description}</p>
              </div>
            </div>
            <div class="mt-3 pt-3 border-t border-[#F59E0B]/30">
              <p class="text-[#F59E0B] text-sm leading-relaxed">{card.extraInfo}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Instructions -->
    <div class="mt-24 text-center">
      <div class="inline-flex items-center gap-4 bg-white/5 backdrop-blur-sm border border-white/10 rounded-full px-6 py-3">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#F59E0B] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#F59E0B]"></span>
        </span>
        <span class="text-white/60 text-sm">Hover inmediato → escala suave | Hover 0.4s → popup flotante</span>
      </div>
    </div>
  </div>
</section>

<!-- Test 2: Single Scale Animation -->
<section class="py-32 bg-[#0A1628] relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-8 lg:px-12 relative z-10">
    <div class="text-center mb-16">
      <span class="inline-block bg-blue-500/20 text-blue-400 px-5 py-2 rounded-full text-sm font-semibold mb-4">Test Zone 2</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Single Scale Test</h2>
      <p class="text-white/60 max-w-xl mx-auto">
        Una caja, dos escalas: 1.3 y 1.8. Sin capas. Solo escala pura.
      </p>
    </div>
    
    <div class="flex flex-col sm:flex-row justify-center gap-4 sm:gap-4 md:gap-6 lg:gap-8">
      <!-- Caja A -->
      <div class="single-scale-card">
        <div class="inner-box w-40 sm:w-48 md:w-56 lg:w-64 h-24 sm:h-28 md:h-28 lg:h-32 relative rounded-xl sm:rounded-2xl cursor-pointer">
          <!-- Contenido principal siempre centrado -->
          <div class="main-content absolute inset-0 z-10 flex items-center justify-center p-2">
            <span class="text-white text-xs sm:text-sm md:text-base font-semibold">Inversión Segura</span>
          </div>
          <!-- Extras en container separado -->
          <div class="extras-container absolute inset-0 z-20 flex flex-col items-center justify-end sm:justify-center pb-3 sm:pt-6 md:pt-8">
            <span class="extra-text text-white/70 text-[10px] sm:text-xs md:text-sm">Retornos 8-12% anual</span>
            <img src="/images/combocaribe-1.png" alt="ComoboCaribe" class="extra-img mt-1 rounded-lg w-12 sm:w-16 md:w-20 h-8 sm:h-10 md:h-12 object-cover" />
            <a href="https://wa.me/573000000000" target="_blank" class="extra-btn mt-1 px-2 sm:px-2 md:px-4 py-1 bg-green-500 hover:bg-green-600 text-[10px] sm:text-xs md:text-sm rounded-lg transition-colors">WhatsApp</a>
          </div>
        </div>
      </div>
      <!-- Caja B -->
      <div class="single-scale-card">
        <div class="inner-box w-40 sm:w-48 md:w-56 lg:w-64 h-24 sm:h-28 md:h-28 lg:h-32 relative rounded-xl sm:rounded-2xl cursor-pointer">
          <!-- Contenido principal siempre centrado -->
          <div class="main-content absolute inset-0 z-10 flex items-center justify-center p-2">
            <span class="text-white text-xs sm:text-sm md:text-base font-semibold">Comunidad Activa</span>
          </div>
          <!-- Extras en container separado -->
          <div class="extras-container absolute inset-0 z-20 flex flex-col items-center justify-end sm:justify-center pb-3 sm:pt-6 md:pt-8">
            <span class="extra-text text-white/70 text-[10px] sm:text-xs md:text-sm">+1,000 miembros</span>
            <img src="/images/combocaribe-2.png" alt="ComoboCaribe" class="extra-img mt-1 rounded-lg w-12 sm:w-16 md:w-20 h-8 sm:h-10 md:h-12 object-cover" />
            <a href="https://wa.me/573000000000" target="_blank" class="extra-btn mt-1 px-2 sm:px-2 md:px-4 py-1 bg-green-500 hover:bg-green-600 text-[10px] sm:text-xs md:text-sm rounded-lg transition-colors">WhatsApp</a>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Instructions -->
    <div class="mt-24 text-center">
      <div class="inline-flex items-center gap-4 bg-white/5 backdrop-blur-sm border border-white/10 rounded-full px-6 py-3">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-400"></span>
        </span>
        <span class="text-white/60 text-sm">Hover inmediato → escala 1.3 | Hover 0.4s → escala 1.8</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Test 2: Single Scale Card */
  .single-scale-card {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: center center;
    position: relative;
    display: grid;
    place-items: center;
  }
  
  .inner-box {
    grid-area: 1 / 1;
    width: 16rem;
    height: 8rem;
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 1rem;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease;
    z-index: 1;
  }
  
  .main-content {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .extras-container {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .extra-img {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  /* Solo mostrar extras en hover 2 (scaled) */
  .single-scale-card.scaled .extras-container {
    opacity: 1;
    transform: translateY(0);
  }
  .single-scale-card.scaled .extra-img {
    opacity: 1;
  }
  
  @media (hover: hover) {
    /* Hover inmediato: lift */
    .single-scale-card:hover .inner-box {
      transform: translateY(-8px);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    }
  }
  
  /* Hover sostenido: scale - más vertical que horizontal */
  .single-scale-card.scaled .inner-box {
    transform: translateY(-10px) scaleX(1.08) scaleY(1.2);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
  }
  .single-scale-card.scaled .main-content {
    transform: scaleX(0.9) scaleY(0.85);
  }
  .single-scale-card.scaled .extras-container {
    transform: scaleX(0.9) scaleY(0.85);
  }
  
  /* Desktop: escala original */
  @media (min-width: 640px) {
    .single-scale-card:hover .inner-box {
      transform: translateY(-12px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }
    .single-scale-card.scaled .inner-box {
      transform: translateY(-12px) scale(1.8);
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
    }
    .single-scale-card.scaled .main-content,
    .single-scale-card.scaled .extras-container {
      transform: scale(0.556);
    }
  }
  
  /* Test 1: Original Hover Cards */
  .hover-layer-card {
    position: relative;
    /* Container maneja la escala para transición continua */
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: center center;
  }
  
  .base-card {
    position: relative;
    z-index: 2;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }
  
  .expanded-card {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    z-index: 1;
    opacity: 0;
    transform: scale(1);
    /* Transición suave */
    transition: opacity 0.3s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    transform-origin: center center;
    /* Altura maxima limitada pero adaptable */
    max-height: 500px;
  }
  
  /* Hover normal: escala sutil - el container escala */
  @media (hover: hover) {
    .hover-layer-card:hover {
      transform: scale(1.03);
    }
    .hover-layer-card:hover .base-card {
      border-color: rgba(245, 158, 11, 0.4);
    }
  }
  
  /* Expanded state: base se esconde, container escala más y popup aparece */
  .hover-layer-card.expanded .base-card {
    opacity: 0;
    pointer-events: none;
  }
  
  .hover-layer-card.expanded {
    transform: scale(1.08);
  }
  
  .hover-layer-card.expanded .expanded-card {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
  }
  
  /* Mobile: tap */
  @media (hover: none) {
    .hover-layer-card.active .base-card {
      opacity: 0;
      pointer-events: none;
    }
    
    .hover-layer-card.active {
      transform: scale(1.08);
    }
    
    .hover-layer-card.active .expanded-card {
      opacity: 1;
      transform: scale(1);
      pointer-events: auto;
    }
  }
</style>

<script>
  // Test 1: Original Hover Cards
  const cards = document.querySelectorAll('.hover-layer-card');
   
  cards.forEach((card) => {
    const el = card as HTMLElement;
    let hoverTimer: number;
     
    // Desktop: hover prolongado
    el.addEventListener('mouseenter', () => {
      hoverTimer = window.setTimeout(() => {
        el.classList.add('expanded');
      }, 400);
    });
     
    el.addEventListener('mouseleave', () => {
      clearTimeout(hoverTimer);
      el.classList.remove('expanded');
    });
     
    // Mobile: tap to toggle
    el.addEventListener('touchend', (e) => {
      e.preventDefault();
       
      cards.forEach((c) => {
        if (c !== el) c.classList.remove('active');
      });
       
      el.classList.toggle('active');
       
      setTimeout(() => {
        el.classList.remove('active');
      }, 3000);
    });
  });
  
  // Test 2: Single Scale Cards
  const singleCards = document.querySelectorAll('.single-scale-card');
   
  singleCards.forEach((card) => {
    const el = card as HTMLElement;
    let hoverTimer: number;
     
    // Desktop: hover prolongado
    el.addEventListener('mouseenter', () => {
      hoverTimer = window.setTimeout(() => {
        el.classList.add('scaled');
      }, 400);
    });
     
    el.addEventListener('mouseleave', () => {
      clearTimeout(hoverTimer);
      el.classList.remove('scaled');
    });
    
    // Mobile: tap to toggle
    el.addEventListener('touchstart', (e) => {
      e.preventDefault();
      el.classList.toggle('scaled');
    });
    
    // Cerrar al hacer tap afuera
    document.addEventListener('touchstart', (e) => {
      if (!el.contains(e.target as Node)) {
        el.classList.remove('scaled');
      }
    });
  });
</script>