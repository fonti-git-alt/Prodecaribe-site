---
const WHATSAPP_PLACEHOLDER = 'https://wa.me/1234567890';

const quickLinks = [
  { label: 'Los Combos', href: '#combos' },
  { label: 'El Problema', href: '#problema' },
  { label: 'Testimonios', href: '#testimonios' },
  { label: 'Nosotros', href: '#nosotros' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0A1628] text-white pt-24 pb-10 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-[#0C4A6E]/20 rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-8 lg:px-12 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20 mb-16">
      <!-- Brand -->
      <div>
        <h3 class="text-2xl font-bold text-[#F59E0B] mb-5">Prodecaribe</h3>
        <p class="text-white/50 mb-8 leading-relaxed max-w-xs">
          Construimos el futuro del Caribe, tu legado en tu tierra natal.
        </p>
        
        <!-- WhatsApp CTA visible -->
        <a href={WHATSAPP_PLACEHOLDER} class="group inline-flex items-center gap-3 bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-full font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-green-500/30 mb-4">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.174-.149.348-.398.522-.601.174-.198.297-.297.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297a11.815 11.815 0 00-6.949-6.949 11.89 11.89 0 00-6.949-6.949 11.853 11.853 0 00-6.949-6.949 11.815 11.815 0 00-6.949-6.949 11.89 11.89 0 00-6.949-6.949A11.815 11.815 0 001.497 0a11.89 11.89 0 00-6.949 6.949 11.815 11.815 0 00-6.949 6.949 11.89 11.89 0 00-6.949 6.949 11.815 11.815 0 00-6.949 6.949A11.89 11.89 0 001.497 24a11.815 11.815 0 006.949-6.949 11.89 11.89 0 006.949-6.949 11.815 11.815 0 006.949-6.949 11.89 11.89 0 006.949-6.949 11.815 11.815 0 006.949-6.949A11.815 11.815 0 0012.497 0a11.89 11.89 0 016.949 6.949 11.815 11.815 0 016.949 6.949 11.89 11.89 0 016.949 6.949 11.815 11.815 0 016.949 6.949A11.89 11.89 0 0012.497 24"/>
          </svg>
          <span>Escríbenos</span>
        </a>
        
        <div class="flex gap-3 mt-4">
          <!-- Facebook -->
          <a href="#" class="w-10 h-10 bg-white/5 hover:bg-blue-600 border border-white/10 hover:border-blue-600 rounded-xl flex items-center justify-center transition-all duration-300 group">
            <svg class="w-5 h-5 text-white/50 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="#" class="w-10 h-10 bg-white/5 hover:bg-gradient-to-br hover:from-purple-600 hover:to-pink-500 border border-white/10 hover:border-transparent rounded-xl flex items-center justify-center transition-all duration-300 group">
            <svg class="w-5 h-5 text-white/50 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h4 class="font-bold text-sm uppercase tracking-widest text-white/40 mb-6">Enlaces rápidos</h4>
        <ul class="space-y-4">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-[#F59E0B] transition-colors inline-flex items-center gap-2 group">
                <span>{link.label}</span>
                <svg class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Contact -->
      <div>
        <h4 class="font-bold text-sm uppercase tracking-widest text-white/40 mb-6">Contacto</h4>
        <ul class="space-y-4 text-white/60">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#38BDF8] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span>contacto@prodecaribe.com</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#38BDF8] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>Barranquilla, Colombia</span>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="pt-8 border-t border-white/10 text-center">
      <p class="text-white/30 text-sm">
        © {currentYear} Fundación Capital Caribe — Prodecaribe. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
