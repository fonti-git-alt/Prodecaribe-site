---
const WHATSAPP_URL = 'https://wa.me/1234567890';

const industries = [
  { emoji: '🏨', name: 'Hotelera' },
  { emoji: '⛏️', name: 'Minería' },
  { emoji: '👕', name: 'Textil' },
  { emoji: '🐄', name: 'Agropecuaria' },
  { emoji: '🏭', name: 'Producción' },
  { emoji: '💊', name: 'Farmacéutica' },
  { emoji: '🏢', name: 'Bienes Raíces' },
  { emoji: '💻', name: 'Tecnología' },
];
---

<section id="oportunidades" class="py-32 bg-[#FAFAFA] relative">
  <!-- Subtle background accent -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-gradient-to-bl from-[#0C4A6E]/3 to-transparent rounded-full blur-3xl -translate-y-1/2"></div>

  <div class="max-w-7xl mx-auto px-8 lg:px-12 relative z-10">
    <!-- Header -->
    <div class="text-center mb-20" data-stagger>
      <span class="inline-block text-[#0C4A6E]/60 text-sm font-semibold uppercase tracking-widest mb-6">Oportunidades</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#0A1628] mb-6 tracking-tight">
        Invierte en 8 industrias<br/>
        <span class="text-[#F59E0B]">del Caribe</span>
      </h2>
      <p class="text-[#64748B] text-lg max-w-xl mx-auto leading-relaxed">
        Hoteles, minas, textiles, ganado, producción, farmacias, bienes raíces y tecnología.
      </p>
    </div>
    
    <!-- Industry grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 lg:gap-5 mb-16" data-stagger>
      {industries.map((industry, i) => (
        <div class="group bg-white rounded-2xl p-6 text-center border border-[#E2E8F0] hover:border-[#0C4A6E]/20 hover:shadow-xl hover:shadow-[#0C4A6E]/5 transition-all duration-500 cursor-pointer">
          <div class="text-4xl mb-4 transform transition-transform group-hover:scale-110 duration-300">{industry.emoji}</div>
          <div class="font-semibold text-[#0A1628] text-sm">{industry.name}</div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a href={WHATSAPP_URL} class="inline-flex items-center gap-3 text-[#0C4A6E] font-semibold hover:text-[#082F49] transition-colors group">
        <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-[#0C4A6E] hover:after:w-full after:transition-all">Ver todas las oportunidades</span>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
