---
const HOTMART_PLACEHOLDER = '#comprar-combo';

const combos = [
  {
    id: 1,
    name: 'Inversión & Empresa',
    subtitle: 'Comercio exterior y proyección internacional',
    description: 'Enfoque en puertos, exportaciones y logística. El Atlántico como puerta de Colombia al mundo.',
    books: ['Atlántico Exportador 120 Años', 'Barranquilla Rumbo a la Excelencia'],
    magazines: ['#1', '#3', '#11', '#13', '#14', '#21'],
    price: 'USD 25',
    popular: false,
    gradient: 'from-[#0C4A6E] to-[#0369A1]',
    accentColor: '#38BDF8',
    quote: 'El Atlántico como puerta de Colombia al mundo.',
  },
  {
    id: 2,
    name: 'Caribe Emprendedor',
    subtitle: 'Marca, región & promoción territorial',
    description: 'Destino de inversiones, negocios, turismo, cultura y bienestar. Herramienta de posicionamiento.',
    books: ['Barranquilla 200 Años', 'Atlántico Empresarial Turístico y Cultural'],
    magazines: ['#2', '#4', '#10', '#12', '#17', '#20'],
    price: 'USD 23',
    popular: false,
    gradient: 'from-pink-500 to-rose-600',
    accentColor: '#FB7185',
    quote: 'El Caribe como territorio de oportunidades.',
  },
  {
    id: 3,
    name: 'Identidad Caribe',
    subtitle: 'Cultura & experiencia Caribe',
    description: 'Historia, orgullo y pertenencia. Ideal para familias y colombianos en el exterior.',
    books: ['Barranquilla Biodiverciudad de Clase Mundial'],
    magazines: ['#8', '#15', '#19', '#22'],
    price: 'USD 20',
    popular: true, // Más accesible
    gradient: 'from-green-600 to-green-700',
    accentColor: '#4ADE80',
    quote: 'Conecta con tus raíces y comparte el Caribe con el mundo.',
  },
  {
    id: 4,
    name: 'Caribe Sostenible',
    subtitle: 'Biodiversidad & sostenibilidad',
    description: 'Alineado con ODS, sostenibilidad e impacto social. Invertir en cultura es invertir en futuro.',
    books: ['Barranquilla Biodiverciudad de Clase Mundial'],
    magazines: ['#7', '#18', '#19'],
    price: 'USD 30',
    popular: false,
    gradient: 'from-emerald-600 to-teal-600',
    accentColor: '#34D399',
    quote: 'Invertir en cultura también es invertir en sostenibilidad.',
  },
  {
    id: 5,
    name: 'Legado Global',
    subtitle: 'El Caribbean a nivel global — Premium',
    description: 'Prestigio, diplomacia y legado histórico. Incluye certificado oficial "Embajador del Caribe Colombiano".',
    books: ['Los 5 Libros de Oro'],
    magazines: ['Los 22 Magazines'],
    price: 'USD 25',
    popular: false,
    premium: true,
    gradient: 'from-[#F59E0B] to-[#D97706]',
    accentColor: '#FCD34D',
    quote: 'Cuando el Caribe se convierte en legado para las futuras generaciones.',
  },
];
---

<section id="combos" class="py-32 bg-white relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-gradient-to-bl from-[#F59E0B]/5 to-transparent rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-8 lg:px-12 relative z-10">
    <!-- Header -->
    <div class="text-center mb-6" data-animate>
      <span class="inline-block bg-[#F59E0B]/10 text-[#0A1628] px-5 py-2 rounded-full text-sm font-semibold mb-6">Tu primera inversión</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#0A1628] mb-6 tracking-tight">
        Hacé parte del club
      </h2>
      <p class="text-[#64748B] text-lg max-w-2xl mx-auto leading-relaxed">
        Tu primera inversión mínima para ser parte de algo más grande. 
        <span class="text-[#0C4A6E] font-medium">Recibís libros y revistas que construyen el futuro del Caribe.</span>
      </p>
    </div>

    <!-- Combo Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
      {combos.map((combo) => (
        <div class={`group relative bg-gradient-to-br {combo.gradient} rounded-2xl p-8 text-white hover:shadow-2xl transition-all duration-500 overflow-hidden flex flex-col ${combo.popular ? 'ring-2 ring-[#FCD34D] ring-offset-4' : ''} ${combo.premium ? 'lg:col-span-1 lg:row-span-2' : ''}`}>
          
          <!-- Popular badge -->
          {combo.popular && (
            <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold">
              MEJOR VALOR
            </div>
          )}
          
          <!-- Premium badge -->
          {combo.premium && (
            <div class="absolute top-4 right-4 bg-white text-[#0A1628] px-3 py-1 rounded-full text-xs font-bold">
              PREMIUM
            </div>
          )}
          
          <!-- Decorative circle -->
          <div class="absolute -bottom-10 -right-10 w-40 h-40 rounded-full bg-white/5 group-hover:scale-150 transition-transform duration-500"></div>
          
          <!-- Content -->
          <div class="relative z-10 flex-1">
            <div class="text-sm font-medium text-white/70 mb-2">COMBOCARIBE #{combo.id}</div>
            <h3 class="text-2xl font-bold mb-1">{combo.name}</h3>
            <p class="text-white/80 text-sm mb-6">{combo.subtitle}</p>
            
            <p class="text-white/70 text-sm mb-6 leading-relaxed">{combo.description}</p>
            
            <!-- Books -->
            <div class="mb-4">
              <div class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-2">Libros</div>
              <div class="space-y-1">
                {combo.books.map((book) => (
                  <div class="flex items-start gap-2 text-sm text-white/90">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.896 1.004 13.201 1 16.25 1c1.747 0 3.007.704 3.752 1.904l-11.25 11.25c-.745.745-1.904.996-1.904 1.904V18.25"/>
                    </svg>
                    <span>{book}</span>
                  </div>
                ))}
              </div>
            </div>
            
            <!-- Magazines count -->
            <div class="mb-6">
              <div class="text-xs font-semibold text-white/60 uppercase tracking-wide mb-2">
                {combo.id === 5 ? 'Magazines' : 'Magazines MBCC'}
              </div>
              <div class="flex flex-wrap gap-1">
                {combo.magazines.map((m) => (
                  <span class="inline-block bg-white/15 backdrop-blur-sm px-2 py-0.5 rounded text-xs">{m}</span>
                ))}
              </div>
            </div>
          </div>
          
          <!-- Price & CTA -->
          <div class="relative z-10 pt-6 border-t border-white/10">
            <div class="flex items-end justify-between mb-4">
              <div>
                <div class="text-xs text-white/60 mb-1">Precio</div>
                <div class="text-3xl font-bold">{combo.price}</div>
              </div>
            </div>
            
            <a href={`${HOTMART_PLACEHOLDER}?combo=${combo.id}`} class="group/btn w-full flex items-center justify-center gap-2 bg-white/20 hover:bg-white hover:text-[#0A1628] backdrop-blur-sm py-3 rounded-xl font-semibold transition-all duration-300">
              <span>Comprar ahora</span>
              <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            
            <p class="text-center text-white/50 text-xs mt-3">{combo.quote}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <div class="text-center mt-12" data-animate>
      <p class="text-[#64748B] text-sm">
        <span class="text-[#0C4A6E] font-medium">Todos los combos incluyen:</span> descarga inmediata en PDF + acceso a la comunidad Prodecaribe
      </p>
    </div>
  </div>
</section>
