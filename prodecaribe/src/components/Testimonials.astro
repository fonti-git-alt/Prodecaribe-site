---
const testimonials = [
  {
    name: 'Carlos M.',
    location: 'Inversionista desde Madrid',
    initials: 'CM',
    avatar: 'https://images.pexels.com/photos/2379004/pexels-photo-2379004.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&fit=crop',
    gradient: 'from-[#F59E0B] to-[#D97706]',
    text: 'Llevo 2 años invirtiendo. Compré el Combo #3 y la experiencia fue increíble. Los libros son de altísima calidad y ya recuperé mi inversión.',
  },
  {
    name: 'Ana P.',
    location: 'Inversionista desde Miami',
    initials: 'AP',
    avatar: 'https://images.pexels.com/photos/415829/pexels-photo-415829.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&fit=crop',
    gradient: 'from-[#0C4A6E] to-[#0369A1]',
    text: 'No conocía nada de inversiones. Prodecaribe me guió en cada paso. Hoy tengo activos en el Caribe y mi familia está orgullosa.',
  },
  {
    name: 'Roberto S.',
    location: 'Empresario desde Barcelona',
    initials: 'RS',
    avatar: 'https://images.pexels.com/photos/1222271/pexels-photo-1222271.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&fit=crop',
    gradient: 'from-green-500 to-green-600',
    text: 'Invertí en el Combo #5 Legado Global. El certificado de Embajador abrió puertas que no esperaba. Es más que una inversión, es pertenencia.',
  },
];
---

<section id="testimonios" class="py-32 bg-[#FAFAFA] relative overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 left-20 w-80 h-80 bg-[#F59E0B]/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-20 w-80 h-80 bg-[#0C4A6E]/5 rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-8 lg:px-12 relative z-10">
    <!-- Header -->
    <div class="text-center mb-20" data-animate>
      <span class="inline-block bg-green-100 text-green-800 px-5 py-2 rounded-full text-sm font-semibold mb-6">✓ Ya lo hicieron</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#0A1628] mb-6 tracking-tight">
        Inversionistas que<br/>
        <span class="text-[#0C4A6E]">ya están ganando</span>
      </h2>
    </div>
    
    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
      {testimonials.map((t) => (
        <div class="bg-white rounded-3xl p-10 border border-[#E2E8F0] hover:border-[#0C4A6E]/20 hover:shadow-xl hover:shadow-[#0C4A6E]/5 transition-all duration-500 relative">
          <!-- Quote mark -->
          <div class="absolute top-6 right-8 text-8xl text-[#E2E8F0] font-serif leading-none select-none">"</div>
          
          <!-- Stars -->
          <div class="flex items-center gap-1 mb-6 relative z-10">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-[#F59E0B]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          
          <!-- Text -->
          <p class="text-[#475569] mb-8 italic leading-relaxed relative z-10">
            "{t.text}"
          </p>
          
          <!-- Author -->
          <div class="flex items-center gap-4 pt-6 border-t border-[#E2E8F0]">
            <img src={t.avatar} alt={t.name} class="w-12 h-12 rounded-full object-cover border-2 border-white shadow-lg" />
            <div>
              <div class="font-bold text-[#0A1628]">{t.name}</div>
              <div class="text-sm text-[#94A3B8]">{t.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Counter badge -->
    <div class="mt-16 text-center" data-animate>
      <div class="inline-flex items-center gap-4 bg-white rounded-full px-8 py-4 border border-[#E2E8F0] shadow-lg">
        <div class="flex -space-x-3">
          <img src="https://images.pexels.com/photos/2379004/pexels-photo-2379004.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&fit=crop" class="w-9 h-9 rounded-full border-2 border-white shadow-md object-cover" alt="Inversionista" />
          <img src="https://images.pexels.com/photos/415829/pexels-photo-415829.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&fit=crop" class="w-9 h-9 rounded-full border-2 border-white shadow-md object-cover" alt="Inversionista" />
          <img src="https://images.pexels.com/photos/1222271/pexels-photo-1222271.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&fit=crop" class="w-9 h-9 rounded-full border-2 border-white shadow-md object-cover" alt="Inversionista" />
        </div>
        <span class="text-[#475569] font-medium pl-2">
          <span class="text-[#0A1628] font-bold">+1,000</span> inversionistas satisfechos
        </span>
      </div>
    </div>
  </div>
</section>
