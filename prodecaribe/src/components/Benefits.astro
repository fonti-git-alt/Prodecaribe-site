---
const clusters = [
  {
    emoji: '🏨',
    name: 'Hotelera',
    description: 'Invertí en proyectos hoteleros en Santa Marta y Cartagena.',
  },
  {
    emoji: '⛏️',
    name: 'Minería',
    description: 'Oportunidades en carbón, esmeraldas y materia prima de joyería.',
  },
  {
    emoji: '👕',
    name: 'Textil',
    description: 'Confecciones de Barranquilla para exportar al mundo.',
  },
  {
    emoji: '🐄',
    name: 'Agropecuaria',
    description: 'Ganado, plátano, yuca. El campo caribeño nunca falla.',
  },
  {
    emoji: '🏭',
    name: 'Producción',
    description: 'Plásticos, alimentos, bebidas. La industria local crece.',
  },
  {
    emoji: '💊',
    name: 'Farmacéutica',
    description: 'Medicamentos genéricos. Un sector en expansión constante.',
  },
  {
    emoji: '🏢',
    name: 'Bienes Raíces',
    description: 'Apartamentos, oficinas y lotes. El Caribe se valoriza.',
  },
  {
    emoji: '💻',
    name: 'Tecnología',
    description: 'Startups, apps y fintech. El nuevo oro del Caribe.',
  },
];
---

<section id="beneficios" class="py-32 bg-gradient-to-b from-[#FAFAFA] to-white relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 w-96 h-96 bg-[#F59E0B]/5 rounded-full blur-3xl -translate-x-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-[#0C4A6E]/5 rounded-full blur-3xl translate-x-1/2"></div>
  </div>

  <div class="max-w-7xl mx-auto px-8 lg:px-12 relative z-10">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <span class="inline-block bg-[#0C4A6E]/8 text-[#0C4A6E] px-5 py-2 rounded-full text-sm font-semibold mb-6">Club de Inversión</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#0A1628] mb-6 tracking-tight">
        Ser miembro tiene <span class="text-[#F59E0B]">beneficios</span>
      </h2>
      <p class="text-[#64748B] text-lg max-w-2xl mx-auto leading-relaxed">
        Al hacerte parte del club, desbloqueás acceso a oportunidades de inversión en los sectores que están transformando el Caribe colombiano.
      </p>
    </div>

    <!-- Main benefits -->
    <div class="grid md:grid-cols-3 gap-6 mb-16" data-stagger>
      <!-- Benefit 1 -->
      <div class="bg-white rounded-2xl p-8 border border-[#E2E8F0] hover:border-[#0C4A6E]/20 hover:shadow-xl hover:shadow-[#0C4A6E]/5 transition-all duration-500">
        <div class="w-14 h-14 bg-[#0C4A6E] rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-[#0A1628] mb-3">Generar Riqueza</h3>
        <p class="text-[#64748B] leading-relaxed">
          Tu dinero trabaja para vos en proyectos con alto potencial de retorno. Inversiones desde USD 5,000.
        </p>
      </div>

      <!-- Benefit 2 -->
      <div class="bg-white rounded-2xl p-8 border border-[#E2E8F0] hover:border-[#F59E0B]/30 hover:shadow-xl hover:shadow-[#F59E0B]/5 transition-all duration-500">
        <div class="w-14 h-14 bg-[#F59E0B] rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-[#0A1628] mb-3">Comprar y Vender</h3>
        <p class="text-[#64748B] leading-relaxed">
          Accedé a una red de contactos para comprar y vender al mejor precio en cualquiera de los 8 clusters.
        </p>
      </div>

      <!-- Benefit 3 -->
      <div class="bg-white rounded-2xl p-8 border border-[#E2E8F0] hover:border-green-500/30 hover:shadow-xl hover:shadow-green-500/5 transition-all duration-500">
        <div class="w-14 h-14 bg-green-500 rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-[#0A1628] mb-3">Comunidad Exclusiva</h3>
        <p class="text-[#64748B] leading-relaxed">
          Conectá con otros inversionistas, empresarios y líderes del Caribe. Networking de alto nivel.
        </p>
      </div>
    </div>

    <!-- 8 Clusters -->
    <div class="bg-gradient-to-br from-[#0A1628] to-[#0C4A6E] rounded-3xl p-10 lg:p-14 relative overflow-hidden" data-animate>
      <!-- Background decoration -->
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 right-0 w-64 h-64 bg-[#F59E0B] rounded-full blur-3xl"></div>
      </div>

      <div class="relative z-10">
        <h3 class="text-2xl lg:text-3xl font-bold text-white mb-8 text-center">
          Los 8 clusters de inversión del Caribe
        </h3>
        
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-5">
          {clusters.map((cluster) => (
            <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10 hover:bg-white/20 transition-all duration-300 group">
              <div class="text-3xl mb-3 transform group-hover:scale-110 transition-transform">{cluster.emoji}</div>
              <h4 class="font-bold text-white mb-1">{cluster.name}</h4>
              <p class="text-white/60 text-xs leading-relaxed">{cluster.description}</p>
            </div>
          ))}
        </div>

        <p class="text-center text-white/50 mt-10 text-sm">
          <span class="text-[#F59E0B] font-medium">Tu primera inversión:</span> Desde USD 20 para acceder al club
        </p>
      </div>
    </div>
  </div>
</section>
