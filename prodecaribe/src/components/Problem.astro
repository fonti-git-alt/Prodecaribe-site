---
---

<section id="problema" class="py-32 bg-[#FAFAFA] relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <!-- IMAGEN: Foto aérea del Caribe colombiano (Barranquilla, Cartagena, Santa Marta) -->
    <!-- <div class="absolute inset-0 bg-[url('/images/caribe-aerial.jpg')] bg-cover bg-center opacity-[0.03]"></div> -->
    <div class="absolute top-20 left-10 text-[180px] select-none opacity-[0.03]">🏝️</div>
    <div class="absolute bottom-20 right-10 text-[180px] select-none opacity-[0.03]">🌴</div>
  </div>
  
  <div class="max-w-5xl mx-auto px-8 lg:px-12 relative z-10">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <span class="inline-block bg-[#0C4A6E]/8 text-[#0C4A6E] px-5 py-2 rounded-full text-sm font-semibold mb-8">Lo que sentís</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#0A1628] leading-tight tracking-tight">
        Estás lejos.<br/>
        <span class="text-[#0C4A6E]">Tu tierra no.</span>
      </h2>
    </div>
    
    <!-- Main card -->
    <div class="bg-white rounded-3xl p-10 lg:p-14 shadow-2xl shadow-[#0A1628]/5 border border-[#E2E8F0]/50 relative overflow-hidden" data-animate>
      <!-- Gradient accent -->
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#0C4A6E] via-[#F59E0B] to-[#F59E0B]"></div>
      
      <!-- Decorative element -->
      <div class="absolute top-8 right-8 w-32 h-32 bg-gradient-to-br from-[#F59E0B]/5 to-transparent rounded-full"></div>
      
      <div class="space-y-8 text-lg text-[#475569] relative z-10">
        <p class="leading-loose">
          <strong class="text-[#0C4A6E] font-semibold">Vivís en otro país.</strong> Trabajás duro. Mandás plata a casa. 
          Pero algo no cierra...
        </p>
        <p class="leading-loose">
          Tu casa en Barranquilla, Cartagena o Santa Marta sigue igual. 
          <strong class="text-[#0C4A6E] font-semibold">Las oportunidades pasan</strong> y vos no estás ahí para aprovecharlas.
        </p>
        <p class="leading-loose">
          Mientras tanto, tu dinero en el banco pierde valor. 
          <strong class="text-[#F59E0B] font-semibold">¿Y si ese dinero trabajara para tu tierra... y para vos?</strong>
        </p>
      </div>
      
      <!-- Quote -->
      <div class="mt-12 pt-8 border-t border-[#E2E8F0]">
        <p class="text-2xl lg:text-3xl font-bold text-[#0C4A6E] text-center leading-snug">
          "El Caribe crece. <span class="text-[#F59E0B]">¿Vas a dejar que crezca sin vos?</span>"
        </p>
      </div>
    </div>
  </div>
</section>
