---
const WHATSAPP_URL = 'https://wa.me/1234567890';

const industries = [
  {
    emoji: '🏨',
    name: 'Hotelera',
    description: 'El turismo está explotando. Santa Marta y Cartagena necesitan más hoteles.',
    rentabilidad: '15-25%',
    gradient: 'from-[#0C4A6E] to-[#0369A1]',
  },
  {
    emoji: '⛏️',
    name: 'Minería',
    description: 'Carbón y esmeraldas. La Guajira y el Cesar son oro negro.',
    rentabilidad: '20-30%',
    gradient: 'from-[#1E293B] to-[#0F172A]',
  },
  {
    emoji: '👕',
    name: 'Textil',
    description: 'Confecciones de Barranquilla vestir al mundo entero.',
    rentabilidad: '12-18%',
    gradient: 'from-pink-500 to-rose-600',
  },
  {
    emoji: '🐄',
    name: 'Agropecuaria',
    description: 'Ganado, plátano, yuca. El campo caribeño nunca falla.',
    rentabilidad: '10-15%',
    gradient: 'from-green-600 to-green-700',
  },
  {
    emoji: '🏭',
    name: 'Producción',
    description: 'Plásticos, alimentos, bebidas. La industria local está creciendo.',
    rentabilidad: '14-20%',
    gradient: 'from-orange-500 to-orange-600',
  },
  {
    emoji: '💊',
    name: 'Farmacéutica',
    description: 'Medicamentos genéricos. Un sector en expansión constante.',
    rentabilidad: '18-25%',
    gradient: 'from-cyan-600 to-cyan-700',
  },
  {
    emoji: '🏢',
    name: 'Bienes Raíces',
    description: 'Apartamentos, oficinas, lotes. El Caribe valorizándose.',
    rentabilidad: '12-22%',
    gradient: 'from-indigo-600 to-indigo-700',
  },
  {
    emoji: '💻',
    name: 'Tecnología',
    description: 'Startups, apps, fintech. El nuevo oro del Caribe.',
    rentabilidad: '25-40%',
    gradient: 'from-violet-600 to-violet-700',
  },
];
---

<section id="industrias" class="py-32 bg-white relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-gradient-to-bl from-[#F59E0B]/5 to-transparent rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-8 lg:px-12 relative z-10">
    <!-- Header -->
    <div class="text-center mb-20" data-animate>
      <span class="inline-block bg-[#F59E0B]/10 text-[#0A1628] px-5 py-2 rounded-full text-sm font-semibold mb-6">Oportunidades Reales</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#0A1628] mb-6 tracking-tight">
        8 industrias con<br/>
        <span class="text-[#F59E0B]">potencial real</span>
      </h2>
      <p class="text-[#64748B] text-lg max-w-2xl mx-auto leading-relaxed">
        Estas no son promesas vacías. Son sectores que ya están moviendo la economía del Caribe colombiano.
      </p>
    </div>
    
    <!-- Industries grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5" data-stagger>
      {industries.map((industry, i) => (
        <div class="group relative bg-gradient-to-br {industry.gradient} rounded-2xl p-8 text-white hover:shadow-2xl transition-all duration-500 overflow-hidden h-full min-h-[220px] flex flex-col justify-between">
          <!-- Decorative circle -->
          <div class="absolute -bottom-10 -right-10 w-32 h-32 rounded-full bg-white/5 group-hover:scale-150 transition-transform duration-500"></div>
          
          <!-- Content -->
          <div class="relative z-10">
            <div class="text-4xl mb-5 transform transition-transform group-hover:scale-110 duration-300">{industry.emoji}</div>
            <h3 class="text-xl font-bold mb-2">{industry.name}</h3>
            <p class="text-white/70 text-sm leading-relaxed">{industry.description}</p>
          </div>
          
          <!-- Rentabilidad badge -->
          <div class="relative z-10 mt-4">
            <span class="inline-block bg-white/15 backdrop-blur-sm px-4 py-1.5 rounded-full text-sm font-medium text-[#FCD34D]">
              {industry.rentabilidad}
            </span>
          </div>
        </div>
      ))}
    </div>
    
    <!-- CTA -->
    <div class="text-center mt-16" data-animate>
      <a href={WHATSAPP_URL} class="group inline-flex items-center gap-4 bg-[#0A1628] hover:bg-[#0C4A6E] text-white px-10 py-5 rounded-full font-semibold text-lg transition-all duration-300 shadow-xl hover:shadow-2xl">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.174-.149.348-.398.522-.601.174-.198.297-.297.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297a11.815 11.815 0 00-6.949-6.949 11.89 11.89 0 00-6.949-6.949 11.853 11.853 0 00-6.949-6.949 11.815 11.815 0 00-6.949-6.949 11.89 11.89 0 00-6.949-6.949A11.815 11.815 0 001.497 0a11.89 11.89 0 00-6.949 6.949 11.815 11.815 0 00-6.949 6.949 11.89 11.89 0 00-6.949 6.949 11.815 11.815 0 00-6.949 6.949A11.89 11.89 0 001.497 24a11.815 11.815 0 006.949-6.949 11.89 11.89 0 006.949-6.949 11.815 11.815 0 006.949-6.949 11.89 11.89 0 006.949-6.949 11.815 11.815 0 006.949-6.949A11.815 11.815 0 0012.497 0a11.89 11.89 0 016.949 6.949 11.815 11.815 0 016.949 6.949 11.89 11.89 0 016.949 6.949 11.815 11.815 0 016.949 6.949A11.89 11.89 0 0012.497 24"/>
        </svg>
        <span>Preguntame sobre una industria</span>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
